DATABASE_URL=sqlite:///./tenderscout.db
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
FREE_CREDITS_ON_SIGNUP=5
CREDITS_PER_RESULT=1

# 6 hours between scrape cycles — 60s is too aggressive for 50+ sites
SCRAPE_INTERVAL_SECONDS=21600

FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional — leave blank to disable email notifications
GMAIL_USER=
GMAIL_PASSWORD=